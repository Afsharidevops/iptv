{
  "name": "iptv-org.github.io",
  "type": "module",
  "private": true,
  "scripts": {
    "act:update": "act workflow_dispatch -W .github/workflows/update.yml",
    "api:load": "tsx src/commands/api/load.ts",
    "data:compile": "tsx src/commands/data/compile.ts",
    "dev": "npm run data:compile && vite dev --host",
    "build": "npm run data:compile && vite build",
    "preview": "npm run build && vite preview --host",
    "prepare": "svelte-kit sync",
    "postinstall": "npm run api:load",
    "postbuild": "npx svelte-sitemap -d https://iptv-org.github.io -o docs",
    "test": "vitest run",
    "lint": "eslint"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@freearhey/search-js": "^0.3.0",
    "@freearhey/storage-js": "^0.2.0",
    "@iptv-org/sdk": "^1.4.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/cli-progress": "^3.11.6",
    "@types/object-hash": "^3.0.6",
    "@zerodevx/svelte-toast": "^0.9.6",
    "cli-progress": "^3.12.0",
    "country-flag-icons": "^1.6.4",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.19",
    "es-toolkit": "^1.46.1",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.13.0",
    "fs-extra": "^11.3.5",
    "globals": "^16.5.0",
    "iptv-playlist-generator": "^0.1.5",
    "msgpackr": "^2.0.1",
    "natural-orderby": "^5.0.0",
    "object-hash": "^3.0.0",
    "p-limit": "^7.3.0",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.45.3",
    "svelte-sitemap": "^2.7.1",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4.3.0",
    "tippy.js": "^6.3.7",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.10",
    "vite-plugin-mkcert": "^1.17.12",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "esbuild": "0.23.1"
  }
}
